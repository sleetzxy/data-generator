# 本地开发配置模板：复制为 application-local.yml 后填入真实密钥（该文件已被 .gitignore 忽略）
#
#   cp application-local.yml.example application-local.yml
#
# application.yml 会通过 spring.config.import 自动加载 application-local.yml（若存在）。
# 也可改用环境变量 DEEPSEEK_API_KEY，无需创建本文件。

ai:
  providers:
    deepseek:
      api-key: sk-your-deepseek-api-key
      # 复杂 Job 生成时可增大，减少 Tool 参数 JSON 被截断
      max-output-tokens: 8192
